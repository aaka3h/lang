import "web"
import "json"
import "http"

fn home() {
    html("<html><body><h1>Hello from Lang!</h1><p>A web server written in Lang.</p><a href='/api/time'>API</a></body></html>")
}

fn api_time() {
    let t = time_now()
    json_response(json_encode({"time": t, "lang": "awesome"}))
}

fn hello() {
    html("<h1>Hello World!</h1>")
}

route("/", home)
route("/api/time", api_time)
route("/hello", hello)

serve(8080)
