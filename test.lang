class Animal {
    fn init(name) {
        self.name = name
    }
    fn speak() {
        print self.name + " makes a sound"
    }
}

class Dog extends Animal {
    fn init(name) {
        super(name)
    }
    fn speak() {
        print self.name + " barks"
    }
}

let d = Dog("Rex")
d.speak()

